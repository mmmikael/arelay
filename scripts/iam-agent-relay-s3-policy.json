{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "ListAgentRelayPrefix",
			"Effect": "Allow",
			"Action": ["s3:ListBucket"],
			"Resource": "arn:aws:s3:::YOUR_BUCKET_NAME",
			"Condition": {
				"StringLike": {
					"s3:prefix": ["agent-relay", "agent-relay/*"]
				}
			}
		},
		{
			"Sid": "ReadWriteAgentRelayObjects",
			"Effect": "Allow",
			"Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
			"Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/agent-relay/*"
		}
	]
}
