# Copy to .env and fill in values: cp .env.example .env
#
# Required for a working deployment:
#   SESSION_SECRET, DATABASE_URL, S3_* (endpoint, bucket, access key, secret key)
#   Plus email delivery in production: Cloudflare or SMTP, with EMAIL_FROM set
#
# Agent API tokens are created per account in the portal UI — not set here.

# --- Runtime ---

# Set to production in deployed environments (secure cookies).
# NODE_ENV=production

# Public site URL used by SvelteKit for CSRF checks and absolute URLs in production.
# On arelay.app, set ORIGIN=https://arelay.app (must match the browser address bar).
# ORIGIN=https://arelay.app

# HTTP port for `npm start`. Defaults to 3000. Railway sets this automatically.
# PORT=3000

# --- Session ---

# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Bump to invalidate all existing human sessions.
SESSION_VERSION=1

# --- Passkeys / WebAuthn ---

# Leave WEBAUTHN_RP_ID and WEBAUTHN_ORIGIN blank locally (defaults from request URL).
# In production on arelay.app, set RP_ID=arelay.app and ORIGIN=https://arelay.app
WEBAUTHN_RP_NAME=Agent Relay
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=

# --- Database ---

# PostgreSQL connection string. Railway provides DATABASE_URL when you add Postgres.
DATABASE_URL=

# --- Email verification ---

# In local development with no provider configured, verification codes are logged to the
# server console. In production, configure Cloudflare Email Sending or SMTP.
#
# Cloudflare Email Sending (preferred when your sending domain uses Cloudflare DNS).
# Takes precedence over SMTP when both are set.
# https://developers.cloudflare.com/email-service/
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# SMTP relay (SendGrid, SES, Postmark, etc.). Used when Cloudflare is not configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Required when Cloudflare or SMTP is configured. Must use an onboarded sending domain.
EMAIL_FROM="Agent Relay <no-reply@yourdomain.com>"

# --- Artifact storage (S3-compatible) ---

S3_ENDPOINT=
S3_BUCKET=
S3_PREFIX=agent-relay
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
