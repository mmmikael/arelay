{
	"name": "agent-relay",
	"version": "0.0.1",
	"description": "End-to-end encrypted inbox for AI agents — deliver artifacts to humans via HTTP API.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mmmikael/arelay.git"
	},
	"bugs": {
		"url": "https://github.com/mmmikael/arelay/issues"
	},
	"homepage": "https://arelay.app",
	"type": "module",
	"scripts": {
		"start": "node build",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
		"db:migrate": "node scripts/migrate-db.mjs",
		"db:migrate:local": "node --env-file=.env scripts/migrate-db.mjs",
		"db:smoke": "node --import tsx scripts/smoke-db-migrations.ts",
		"db:studio": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/postcss": "^4.1.13",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^22.14.1",
		"@types/nodemailer": "^8.0.0",
		"bits-ui": "0.22.0",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "^13.1.3",
		"postcss": "^8.5.3",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwind-merge": "^3.2.0",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.1.13",
		"tsx": "^4.19.4",
		"typescript": "^5.0.0",
		"vite": "^6.2.5",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.700.0",
		"@aws-sdk/s3-request-presigner": "^3.700.0",
		"@lucide/svelte": "^0.511.0",
		"@simplewebauthn/browser": "^13.3.0",
		"@simplewebauthn/server": "^13.3.1",
		"drizzle-orm": "^0.45.2",
		"fflate": "^0.8.2",
		"marked": "^15.0.12",
		"nodemailer": "^8.0.10",
		"pino": "^10.3.1",
		"postgres": "^3.4.7"
	}
}
